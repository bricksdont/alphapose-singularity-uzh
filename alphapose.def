Bootstrap: docker
From: nvidia/cuda:12.1.0-cudnn8-devel-ubuntu22.04

%labels
    Author Mathias Müller
    Description AlphaPose pose estimation container

%setup
    # The UZH ScienceCluster automatically bind-mounts /apps, /shares, /scratch
    # etc. into containers. The destination directories must exist in the container
    # before the build can proceed, otherwise apptainer fails with:
    #   "destination /apps doesn't exist in container"
    # $APPTAINER_ROOTFS (Apptainer) and $SINGULARITY_ROOTFS (SingularityCE) both
    # point to the container sandbox during %setup; use whichever is set.
    ROOTFS="${APPTAINER_ROOTFS:-${SINGULARITY_ROOTFS:-}}"
    mkdir -p \
        "$ROOTFS/apps" \
        "$ROOTFS/shares" \
        "$ROOTFS/scratch" \
        "$ROOTFS/work" \
        "$ROOTFS/data" \
        "$ROOTFS/project" \
        "$ROOTFS/cluster"

%post
    # Suppress interactive prompts during apt installs
    export DEBIAN_FRONTEND=noninteractive

    # When building with --ignore-fakeroot-command (required on clusters where the
    # bundled fakeroot binaries require a newer glibc than the base image has),
    # apt-get tries to drop privileges to the _apt user via setgroups/seteuid,
    # which is not permitted in a user namespace. Tell apt to stay as root.
    echo 'APT::Sandbox::User "root";' > /etc/apt/apt.conf.d/00no-sandbox

    # Install system dependencies
    apt-get update && apt-get install -y \
        git \
        libyaml-dev \
        wget \
        libgl1-mesa-glx \
        libglib2.0-0 \
        && rm -rf /var/lib/apt/lists/*

    # Install Miniforge with Python 3.10 at /opt/conda
    # Miniforge uses conda-forge by default — no Anaconda TOS required.
    # (run scripts expect Python at /opt/conda/lib/python3.10/)
    wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh \
        -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p /opt/conda
    rm /tmp/miniforge.sh
    export PATH=/opt/conda/bin:$PATH
    conda install -y python=3.10
    conda clean -afy

    # Install PyTorch 2.1.0 with CUDA 12.1
    pip install --no-cache-dir \
        torch==2.1.0 torchvision torchaudio \
        --index-url https://download.pytorch.org/whl/cu121

    # Install Python dependencies
    pip install --no-cache-dir \
        setuptools \
        cython \
        "numpy==1.26.4" \
        "opencv-python==4.11.0.86" \
        scipy \
        tqdm \
        munkres \
        easydict \
        halpecocotools \
        pyyaml \
        tensorboardX \
        gdown

    # Clone AlphaPose
    git clone https://github.com/MVIG-SJTU/AlphaPose.git /opt/alphapose

    # Checkout known-working commit (verified by GerrySant install script)
    git -C /opt/alphapose checkout c60106d19afb443e964df6f06ed1842962f5f1f7

    # Set CUDA paths for build
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH

    # Explicitly set CUDA arch list — required when building without a GPU
    # (torch cannot auto-detect architectures at build time in a container)
    # Includes sm_90 for H100/H200 (Hopper architecture)
    export TORCH_CUDA_ARCH_LIST="6.0 6.1 7.0 7.5 8.0 8.6 9.0"

    # Pre-install matplotlib and contourpy via pip to avoid easy_install
    # trying to fetch contourpy>=1.0.1 from source — newer contourpy dropped
    # setup.py and easy_install cannot handle pyproject.toml-only packages.
    pip install --no-cache-dir matplotlib contourpy

    # Build AlphaPose
    cd /opt/alphapose && python setup.py build develop

    # Create directories for model bind mounts
    mkdir -p /opt/alphapose/detector/yolo/data
    mkdir -p /opt/alphapose/pretrained_models

%environment
    export PATH=/opt/conda/bin:/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export PYTHONPATH=/opt/alphapose

%runscript
    cd /opt/alphapose
    exec python scripts/demo_inference.py "$@"
