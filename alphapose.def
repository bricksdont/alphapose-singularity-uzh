Bootstrap: oras
From: ghcr.io/bricksdont/alphapose-singularity-uzh/alphapose-base:latest

%labels
    Author Mathias Müller
    Description AlphaPose pose estimation container (layered on alphapose-base)

%post
    # Add extra Python dependencies here as needed, e.g.:
    # pip install --no-cache-dir some-package==1.2.3

%environment
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export PYTHONPATH=/opt/alphapose

%runscript
    cd /opt/alphapose
    exec python scripts/demo_inference.py "$@"
